{
  "name": "Playwright E2E Monitoring",
  "description": "Monitors Playwright test jobs across CI pipelines — DEV, TST, TST (PR), PPRD",
  "permissions": "PUBLIC_READ_WRITE",
  "pages": [
    {
      "name": "Overview",
      "description": null,
      "widgets": [
        {
          "title": "Total Tests",
          "layout": { "column": 1, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT count(*) AS 'Total Tests' FROM Span WHERE test.case.result.status IS NOT NULL SINCE 1 week ago"
              }
            ]
          }
        },
        {
          "title": "Passing Tests",
          "layout": { "column": 4, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT count(*) AS 'Passing' FROM Span WHERE test.case.result.status = 'pass' SINCE 1 week ago"
              }
            ],
            "thresholds": [
              { "alertSeverity": "NOT_ALERTING", "value": 0 }
            ]
          }
        },
        {
          "title": "Failing Tests",
          "layout": { "column": 7, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT count(*) AS 'Failing' FROM Span WHERE test.case.result.status = 'fail' SINCE 1 week ago"
              }
            ],
            "thresholds": [
              { "alertSeverity": "CRITICAL", "value": 1 }
            ]
          }
        },
        {
          "title": "Failure Rate",
          "layout": { "column": 10, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT percentage(count(*), WHERE test.case.result.status = 'fail') AS 'Failure Rate %' FROM Span WHERE test.case.result.status IS NOT NULL SINCE 1 week ago"
              }
            ],
            "thresholds": [
              { "alertSeverity": "WARNING", "value": 10 },
              { "alertSeverity": "CRITICAL", "value": 25 }
            ]
          }
        },
        {
          "title": "Pass/Fail Rate Over Time",
          "layout": { "column": 1, "row": 4, "width": 8, "height": 4 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT percentage(count(*), WHERE test.case.result.status = 'pass') AS 'Pass Rate %', percentage(count(*), WHERE test.case.result.status = 'fail') AS 'Fail Rate %' FROM Span WHERE test.case.result.status IS NOT NULL SINCE 4 weeks ago TIMESERIES 1 day"
              }
            ]
          }
        },
        {
          "title": "Tests by Status",
          "layout": { "column": 9, "row": 4, "width": 4, "height": 4 },
          "visualization": { "id": "viz.pie" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT count(*) FROM Span WHERE test.case.result.status IS NOT NULL FACET test.case.result.status SINCE 1 week ago"
              }
            ]
          }
        },
        {
          "title": "Results by Environment",
          "layout": { "column": 1, "row": 8, "width": 6, "height": 4 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT count(*) FROM Span WHERE test.case.result.status IS NOT NULL FACET env.tag, test.case.result.status SINCE 1 week ago"
              }
            ]
          }
        },
        {
          "title": "Results by Browser",
          "layout": { "column": 7, "row": 8, "width": 6, "height": 4 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT count(*) FROM Span WHERE test.case.result.status IS NOT NULL FACET browser.name, test.case.result.status SINCE 1 week ago"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Performance",
      "description": null,
      "widgets": [
        {
          "title": "Average Job Runtime by Environment",
          "layout": { "column": 1, "row": 1, "width": 8, "height": 4 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT average(duration.ms) / 1000 AS 'Avg Duration (s)' FROM Span WHERE name = 'playwright-test-suite' FACET env.tag SINCE 4 weeks ago TIMESERIES 1 day"
              }
            ]
          }
        },
        {
          "title": "Job Runtime per Execution",
          "layout": { "column": 9, "row": 1, "width": 4, "height": 4 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT latest(duration.ms) / 1000 AS 'Last Run (s)', average(duration.ms) / 1000 AS 'Avg (s)', max(duration.ms) / 1000 AS 'Max (s)' FROM Span WHERE name = 'playwright-test-suite' SINCE 1 week ago"
              }
            ]
          }
        },
        {
          "title": "Slowest Tests (Average Duration)",
          "layout": { "column": 1, "row": 5, "width": 12, "height": 4 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT average(duration.ms) AS 'Avg Duration (ms)' FROM Span WHERE test.case.result.status IS NOT NULL FACET test.case.name SINCE 1 week ago LIMIT 20"
              }
            ]
          }
        },
        {
          "title": "Test Duration Distribution",
          "layout": { "column": 1, "row": 9, "width": 12, "height": 4 },
          "visualization": { "id": "viz.histogram" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT histogram(duration.ms, 10, 20) FROM Span WHERE test.case.result.status IS NOT NULL SINCE 1 week ago"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Failures & Flakes",
      "description": null,
      "widgets": [
        {
          "title": "Top Failing Tests",
          "layout": { "column": 1, "row": 1, "width": 6, "height": 5 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT count(*) AS 'Failures' FROM Span WHERE test.case.result.status = 'fail' FACET test.case.name SINCE 1 week ago LIMIT 10"
              }
            ]
          }
        },
        {
          "title": "Flaky Tests",
          "layout": { "column": 7, "row": 1, "width": 6, "height": 5 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT count(*) AS 'Flaky Runs' FROM Span WHERE test.flaky = true FACET test.case.name SINCE 1 week ago LIMIT 10"
              }
            ]
          }
        },
        {
          "title": "Flake Rate Over Time",
          "layout": { "column": 1, "row": 6, "width": 8, "height": 4 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT percentage(count(*), WHERE test.flaky = true) AS 'Flake Rate %' FROM Span WHERE test.case.result.status IS NOT NULL SINCE 4 weeks ago TIMESERIES 1 day"
              }
            ]
          }
        },
        {
          "title": "Overall Flake Rate",
          "layout": { "column": 9, "row": 6, "width": 4, "height": 4 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT percentage(count(*), WHERE test.flaky = true) AS 'Flake Rate %' FROM Span WHERE test.case.result.status IS NOT NULL SINCE 1 week ago"
              }
            ],
            "thresholds": [
              { "alertSeverity": "WARNING", "value": 5 },
              { "alertSeverity": "CRITICAL", "value": 15 }
            ]
          }
        },
        {
          "title": "Failed Test Details",
          "layout": { "column": 1, "row": 10, "width": 12, "height": 5 },
          "visualization": { "id": "viz.table" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT timestamp, test.case.name, env.tag, browser.name, squad.owner, code.filepath, error.message FROM Span WHERE test.case.result.status = 'fail' SINCE 1 week ago LIMIT 50"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "By Environment",
      "description": null,
      "widgets": [
        {
          "title": "DEV — Pass/Fail Over Time",
          "layout": { "column": 1, "row": 1, "width": 6, "height": 4 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT percentage(count(*), WHERE test.case.result.status = 'pass') AS 'Pass %' FROM Span WHERE test.case.result.status IS NOT NULL AND env.tag = 'dev' SINCE 4 weeks ago TIMESERIES 1 day"
              }
            ]
          }
        },
        {
          "title": "TST — Pass/Fail Over Time",
          "layout": { "column": 7, "row": 1, "width": 6, "height": 4 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT percentage(count(*), WHERE test.case.result.status = 'pass') AS 'Pass %' FROM Span WHERE test.case.result.status IS NOT NULL AND env.tag = 'tst' SINCE 4 weeks ago TIMESERIES 1 day"
              }
            ]
          }
        },
        {
          "title": "TST (PR) — Pass/Fail Over Time",
          "layout": { "column": 1, "row": 5, "width": 6, "height": 4 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT percentage(count(*), WHERE test.case.result.status = 'pass') AS 'Pass %' FROM Span WHERE test.case.result.status IS NOT NULL AND env.tag = 'pr' SINCE 4 weeks ago TIMESERIES 1 day"
              }
            ]
          }
        },
        {
          "title": "PPRD — Pass/Fail Over Time",
          "layout": { "column": 7, "row": 5, "width": 6, "height": 4 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT percentage(count(*), WHERE test.case.result.status = 'pass') AS 'Pass %' FROM Span WHERE test.case.result.status IS NOT NULL AND env.tag = 'pprd' SINCE 4 weeks ago TIMESERIES 1 day"
              }
            ]
          }
        },
        {
          "title": "Failure Rate by Environment",
          "layout": { "column": 1, "row": 9, "width": 12, "height": 4 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT percentage(count(*), WHERE test.case.result.status = 'fail') AS 'Failure Rate %' FROM Span WHERE test.case.result.status IS NOT NULL FACET env.tag SINCE 4 weeks ago TIMESERIES 1 day"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "By Squad",
      "description": null,
      "widgets": [
        {
          "title": "Failures by Squad",
          "layout": { "column": 1, "row": 1, "width": 6, "height": 4 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT count(*) AS 'Failures' FROM Span WHERE test.case.result.status = 'fail' FACET squad.owner SINCE 1 week ago"
              }
            ]
          }
        },
        {
          "title": "Pass Rate by Squad",
          "layout": { "column": 7, "row": 1, "width": 6, "height": 4 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT percentage(count(*), WHERE test.case.result.status = 'pass') AS 'Pass Rate %' FROM Span WHERE test.case.result.status IS NOT NULL FACET squad.owner SINCE 1 week ago"
              }
            ]
          }
        },
        {
          "title": "Flake Rate by Squad",
          "layout": { "column": 1, "row": 5, "width": 6, "height": 4 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT percentage(count(*), WHERE test.flaky = true) AS 'Flake Rate %' FROM Span WHERE test.case.result.status IS NOT NULL FACET squad.owner SINCE 1 week ago"
              }
            ]
          }
        },
        {
          "title": "All Test Results",
          "layout": { "column": 1, "row": 9, "width": 12, "height": 5 },
          "visualization": { "id": "viz.table" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [$accountId],
                "query": "SELECT timestamp, test.case.name, test.case.result.status, env.tag, browser.name, squad.owner, test.retry, test.flaky, duration.ms FROM Span WHERE test.case.result.status IS NOT NULL SINCE 1 week ago LIMIT 100"
              }
            ]
          }
        }
      ]
    }
  ]
}
